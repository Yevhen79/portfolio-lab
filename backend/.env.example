# Portfolio Lab backend configuration template.
# Copy to `.env` and fill in REAL values. Never commit the real .env.
#
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to start if SECRET_KEY is missing, a known placeholder,
# or shorter than 32 chars (see app/config.py validation).
SECRET_KEY=CHANGE_ME_run_python_secrets_token_urlsafe_48
# Access-token lifetime in minutes. 1440 = 24h. Revocation is via
# User.token_version, so you don't need an aggressively short value.
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./data/portfolio_lab.db
# Initial admin account, created on first `python seed.py`. Use a real
# email and a STRONG password (16+ chars). The app refuses placeholders.
ADMIN_EMAIL=CHANGE_ME@example.com
ADMIN_PASSWORD=CHANGE_ME_use_a_16_plus_char_random_password
ADMIN_NAME=Admin
DEFAULT_DAILY_LIMIT=5
# DEFAULT_WEEKLY_LIMIT=  # uncomment + set integer to enforce a weekly cap
PRICES_CACHE_DIR=./data/prices
EXPORTS_DIR=./data/exports
BACKUPS_DIR=./data/backups
LOGS_DIR=./logs
LIBERTEX_CACHE_FILE=./data/libertex_assets.json
RISK_FREE_TICKER=^TNX
DEFAULT_HISTORY_YEARS=20
DEFAULT_MIN_HISTORY_YEARS=6
MONTE_CARLO_SIMULATIONS=5000
SPARSIFICATION_THRESHOLD=0.01
# Comma-separated allowed CORS origins. NEVER use "*". Include only your
# real frontend origins (local dev + your public tunnel domain).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
